{
  "name": "codex-provider-history-fixer",
  "version": "0.1.0",
  "description": "A desktop utility that retargets local Codex history sessions to the active model provider.",
  "type": "module",
  "main": "dist-electron/main.js",
  "bin": {
    "codex-provider-history-fixer": "bin/cli.js"
  },
  "files": [
    "dist",
    "dist-electron",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "clean": "node -e \"const fs=require('fs'); for (const dir of ['dist','dist-electron','release']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "build": "npm run clean && tsc -p tsconfig.json && vite build && tsc -p electron/tsconfig.json && node -e \"require('fs').copyFileSync('electron/preload.cjs','dist-electron/preload.cjs')\"",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json && tsc -p electron/tsconfig.json",
    "prepack": "npm run build",
    "package": "npm run build && electron-builder --dir",
    "package:dir": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win portable nsis",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "codex",
    "provider",
    "history",
    "electron",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0",
    "toml": "^3.0.0"
  },
  "optionalDependencies": {
    "electron": "^33.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.codex.provider-history-fixer",
    "productName": "Codex Provider History Fixer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
