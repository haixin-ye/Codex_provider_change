{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"]
  },
  "include": ["*.ts", "core/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
